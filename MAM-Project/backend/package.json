{
  "name": "meditation-app-backend",
  "version": "1.0.0",
  "description": "Backend API for meditation app",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:db": "node tests/run-all-tests.js",
    "test:quick": "node tests/quick-test.js",
    "test:summary": "node tests/test-summary.js",
    "setup:db": "node scripts/setup-database.js",
    "migrate": "node scripts/setup-database.js",
    "test:connection": "node scripts/test-connection.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.16"
  },
  "keywords": [
    "meditation",
    "api",
    "supabase",
    "postgresql"
  ],
  "author": "",
  "license": "MIT"
}
